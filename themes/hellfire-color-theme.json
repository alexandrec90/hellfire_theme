    // ── Activity bar ────────────────────────────────────────────────────────
    "activityBar.background": "#0a0000",
    "activityBar.foreground": "#ff5533",
    "activityBar.inactiveForeground": "#551111",
    "activityBar.border": "#220000",
    "activityBarBadge.background": "#cc1100",
    "activityBarBadge.foreground": "#ffffff",

    // ── Sidebar ─────────────────────────────────────────────────────────────
    "sideBar.background": "#0d0000",
    "sideBar.foreground": "#cc8866",
    "sideBar.border": "#1a0000",
    "sideBarTitle.foreground": "#ff5533",
    "sideBarSectionHeader.background": "#1a0000",
    "sideBarSectionHeader.foreground": "#ff4422",
    "sideBarSectionHeader.border": "#330000",
    "list.activeSelectionBackground": "#3d0000",
    "list.activeSelectionForeground": "#ffaa88",
    "list.inactiveSelectionBackground": "#280000",
    "list.inactiveSelectionForeground": "#cc8866",
    "list.hoverBackground": "#1f0000",
    "list.hoverForeground": "#ff7755",
    "list.focusBackground": "#3d0000",
    "list.focusForeground": "#ffaa88",
    "list.highlightForeground": "#ff5533",
    "list.errorForeground": "#ff2200",
    "list.warningForeground": "#ff8800",
    "listFilterWidget.background": "#1a0000",
    "listFilterWidget.outline": "#550000",
    "listFilterWidget.noMatchesOutline": "#880000",

    // ── Status bar ──────────────────────────────────────────────────────────
    "statusBar.background": "#1a0000",
    "statusBar.foreground": "#ff7755",
    "statusBar.border": "#330000",
    "statusBar.noFolderBackground": "#200000",
    "statusBar.debuggingBackground": "#660000",
    "statusBar.debuggingForeground": "#ffddcc",
    "statusBarItem.hoverBackground": "#3d0000",
    "statusBarItem.remoteBackground": "#880000",
    "statusBarItem.remoteForeground": "#ffddcc",
    "statusBarItem.errorBackground": "#aa1100",
    "statusBarItem.warningBackground": "#884400",

    // ── Title bar ───────────────────────────────────────────────────────────
    "titleBar.activeBackground": "#0f0000",
    "titleBar.activeForeground": "#ff7755",
    "titleBar.inactiveBackground": "#0a0000",
    "titleBar.inactiveForeground": "#662222",
    "titleBar.border": "#220000",

    // ── Tabs ────────────────────────────────────────────────────────────────
    "tab.activeBackground": "#1a0000",
    "tab.activeForeground": "#ff7755",
    "tab.activeBorder": "#ff4400",
    "tab.activeBorderTop": "#00000000",
    "tab.inactiveBackground": "#0d0000",
    "tab.inactiveForeground": "#663333",
    "tab.hoverBackground": "#1f0000",
    "tab.hoverForeground": "#ff9977",
    "tab.border": "#1a0000",
    "tab.unfocusedActiveBackground": "#120000",
    "tab.unfocusedActiveForeground": "#994444",
    "editorGroupHeader.tabsBackground": "#080000",
    "editorGroupHeader.tabsBorder": "#1a0000",

    // ── Panel (terminal etc.) ───────────────────────────────────────────────
    "panel.background": "#0a0000",
    "panel.border": "#330000",
    "panelTitle.activeForeground": "#ff5533",
    "panelTitle.activeBorder": "#ff4400",
    "panelTitle.inactiveForeground": "#662222",

    // ── Terminal ────────────────────────────────────────────────────────────
    "terminal.background": "#080000",
    "terminal.foreground": "#f0c090",
    "terminal.ansiBlack": "#1a0000",
    "terminal.ansiRed": "#ff2200",
    "terminal.ansiGreen": "#88cc22",
    "terminal.ansiYellow": "#ff8800",
    "terminal.ansiBlue": "#ff4422",
    "terminal.ansiMagenta": "#cc2255",
    "terminal.ansiCyan": "#ff6633",
    "terminal.ansiWhite": "#f0c090",
    "terminal.ansiBrightBlack": "#550000",
    "terminal.ansiBrightRed": "#ff5533",
    "terminal.ansiBrightGreen": "#aaee44",
    "terminal.ansiBrightYellow": "#ffaa22",
    "terminal.ansiBrightBlue": "#ff6644",
    "terminal.ansiBrightMagenta": "#ee4477",
    "terminal.ansiBrightCyan": "#ff8855",
    "terminal.ansiBrightWhite": "#fff0e0",
    "terminal.selectionBackground": "#6b000066",
    "terminalCursor.foreground": "#ff4400",

    // ── Input / dropdowns ───────────────────────────────────────────────────
    "input.background": "#0f0000",
    "input.border": "#440000",
    "input.foreground": "#f0c090",
    "input.placeholderForeground": "#662233",
    "inputOption.activeBackground": "#3d0000",
    "inputOption.activeBorder": "#880000",
    "inputOption.activeForeground": "#ff9977",
    "dropdown.background": "#0f0000",
    "dropdown.border": "#440000",
    "dropdown.foreground": "#f0c090",
    "dropdown.listBackground": "#0f0000",

    // ── Buttons ─────────────────────────────────────────────────────────────
    "button.background": "#880000",
    "button.foreground": "#ffffff",
    "button.hoverBackground": "#aa1100",
    "button.secondaryBackground": "#330000",
    "button.secondaryForeground": "#ff7755",
    "button.secondaryHoverBackground": "#550000",

    // ── Scrollbar ───────────────────────────────────────────────────────────
    "scrollbar.shadow": "#00000080",
    "scrollbarSlider.background": "#55000040",
    "scrollbarSlider.hoverBackground": "#88000060",
    "scrollbarSlider.activeBackground": "#bb000080",

    // ── Minimap ─────────────────────────────────────────────────────────────
    "minimap.background": "#080000cc",
    "minimap.selectionHighlight": "#6b000099",
    "minimap.errorHighlight": "#ff220099",
    "minimap.warningHighlight": "#ff880099",
    "minimap.findMatchHighlight": "#cc440099",
    "minimapSlider.background": "#44000050",
    "minimapSlider.hoverBackground": "#66000070",
    "minimapSlider.activeBackground": "#88000090",

    // ── Breadcrumbs ─────────────────────────────────────────────────────────
    "breadcrumb.background": "#0a0000",
    "breadcrumb.foreground": "#884422",
    "breadcrumb.activeSelectionForeground": "#ff7755",
    "breadcrumb.focusForeground": "#ff5533",
    "breadcrumbPicker.background": "#0f0000",

    // ── Peek / code lens ────────────────────────────────────────────────────
    "peekView.border": "#660000",
    "peekViewEditor.background": "#0c0000",
    "peekViewEditor.matchHighlightBackground": "#882200aa",
    "peekViewResult.background": "#0f0000",
    "peekViewResult.fileForeground": "#ff7755",
    "peekViewResult.lineForeground": "#cc8866",
    "peekViewResult.matchHighlightBackground": "#66110099",
    "peekViewResult.selectionBackground": "#3d0000",
    "peekViewResult.selectionForeground": "#ff9977",
    "peekViewTitle.background": "#1a0000",
    "peekViewTitleDescription.foreground": "#cc6644",
    "peekViewTitleLabel.foreground": "#ff7755",
    "editorCodeLens.foreground": "#662222",

    // ── Notifications ───────────────────────────────────────────────────────
    "notificationCenter.border": "#440000",
    "notificationCenterHeader.background": "#1a0000",
    "notificationCenterHeader.foreground": "#ff5533",
    "notifications.background": "#0f0000",
    "notifications.border": "#330000",
    "notifications.foreground": "#cc8866",
    "notificationsErrorIcon.foreground": "#ff2200",
    "notificationsWarningIcon.foreground": "#ff8800",
    "notificationsInfoIcon.foreground": "#ff5533",

    // ── Command palette / quick pick ────────────────────────────────────────
    "quickInput.background": "#0f0000",
    "quickInput.foreground": "#f0c090",
    "quickInputList.focusBackground": "#3d0000",
    "quickInputList.focusForeground": "#ffaa88",
    "quickInputList.focusIconForeground": "#ff7755",

    // ── Git decorations ─────────────────────────────────────────────────────
    "gitDecoration.addedResourceForeground": "#88cc22",
    "gitDecoration.modifiedResourceForeground": "#ff8800",
    "gitDecoration.deletedResourceForeground": "#ff2200",
    "gitDecoration.untrackedResourceForeground": "#cc6600",
    "gitDecoration.ignoredResourceForeground": "#551111",
    "gitDecoration.conflictingResourceForeground": "#ff2255",
    "gitDecoration.stageModifiedResourceForeground": "#ffaa22",
    "gitDecoration.stageDeletedResourceForeground": "#ff5533",

    // ── Misc ────────────────────────────────────────────────────────────────
    "focusBorder": "#660000",
    "foreground": "#cc8866",
    "descriptionForeground": "#884422",
    "errorForeground": "#ff2200",
    "icon.foreground": "#ff5533",
    "selection.background": "#6b000080",
    "widget.shadow": "#000000aa",
    "badge.background": "#cc1100",
    "badge.foreground": "#ffffff",
    "progressBar.background": "#cc1100",
    "textLink.foreground": "#ff6644",
    "textLink.activeForeground": "#ff8866",
    "textPreformat.foreground": "#ff8844",
    "textBlockQuote.background": "#0f0000",
    "textBlockQuote.border": "#660000",
    "textCodeBlock.background": "#0f0000",
    "symbolIcon.classForeground": "#ff6600",
    "symbolIcon.functionForeground": "#ff4400",
    "symbolIcon.variableForeground": "#ffaa44",
    "symbolIcon.keywordForeground": "#ff2200",
    "symbolIcon.stringForeground": "#ff8844",
    "symbolIcon.numberForeground": "#ff6633",
    "symbolIcon.constructorForeground": "#ff5500",
    "symbolIcon.interfaceForeground": "#ff7744",
    "symbolIcon.moduleForeground": "#ff3311",
    "symbolIcon.propertyForeground": "#ffbb66",
    "symbolIcon.enumForeground": "#ff6622",
    "symbolIcon.enumMemberForeground": "#ff9955"
  },
  "tokenColors": [
    // ── Comments ───────────────────────────────────────────────────────────
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#cc7744",
        "fontStyle": "italic"
      }
    },
    // ── Keywords ───────────────────────────────────────────────────────────
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.other.important"
      ],
      "settings": {
        "foreground": "#ff3311",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Storage keywords",
      "scope": ["storage", "storage.type", "storage.modifier"],
      "settings": {
        "foreground": "#ff5522",
        "fontStyle": "bold"
      }
    },
    // ── Operators ──────────────────────────────────────────────────────────
    {
      "name": "Operators",
      "scope": ["keyword.operator"],
      "settings": {
        "foreground": "#ff6633"
      }
    },
    // ── Strings ────────────────────────────────────────────────────────────
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.interpolated"
      ],
      "settings": {
        "foreground": "#ffaa55"
      }
    },
    {
      "name": "String escape / special chars",
      "scope": [
        "constant.character.escape",
        "string.regexp",
        "keyword.operator.quantifier.regexp"
      ],
      "settings": {
        "foreground": "#ff7722"
      }
    },
    // ── Numbers / booleans ─────────────────────────────────────────────────
    {
      "name": "Numbers",
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "#ff6644"
      }
    },
    {
      "name": "Boolean / null",
      "scope": ["constant.language"],
      "settings": {
        "foreground": "#ff4422",
        "fontStyle": "bold"
      }
    },
    // ── Functions ──────────────────────────────────────────────────────────
    {
      "name": "Function names",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call entity.name.function"
      ],
      "settings": {
        "foreground": "#ff7744"
      }
    },
    {
      "name": "Function parameters",
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#ffcc88",
        "fontStyle": "italic"
      }
    },
    // ── Types / classes ────────────────────────────────────────────────────
    {
      "name": "Classes / types",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "support.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#ff8855"
      }
    },
    {
      "name": "Type annotations",
      "scope": [
        "entity.name.type.alias",
        "entity.name.type.class",
        "entity.name.type.interface"
      ],
      "settings": {
        "foreground": "#ff9966"
      }
    },
    {
      "name": "Inherited class",
      "scope": ["entity.other.inherited-class"],
      "settings": {
        "foreground": "#ff7744",
        "fontStyle": "italic"
      }
    },
    // ── Variables ──────────────────────────────────────────────────────────
    {
      "name": "Variables",
      "scope": ["variable", "variable.other.readwrite"],
      "settings": {
        "foreground": "#f0c090"
      }
    },
    {
      "name": "Properties / members",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#ffbb77"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "variable.other.constant",
        "constant.other"
      ],
      "settings": {
        "foreground": "#ff9944",
        "fontStyle": "bold"
      }
    },
    // ── Punctuation ────────────────────────────────────────────────────────
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "meta.brace",
        "punctuation.bracket",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#cc5533"
      }
    },
    // ── Tags (HTML/JSX) ────────────────────────────────────────────────────
    {
      "name": "HTML / JSX tag names",
      "scope": [
        "entity.name.tag",
        "support.class.component"
      ],
      "settings": {
        "foreground": "#ff4422",
        "fontStyle": "bold"
      }
    },
    {
      "name": "HTML / JSX attributes",
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#ff8844"
      }
    },
    // ── CSS ────────────────────────────────────────────────────────────────
    {
      "name": "CSS selectors",
      "scope": [
        "entity.name.tag.css",
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#ff5533"
      }
    },
    {
      "name": "CSS properties",
      "scope": ["support.type.property-name.css"],
      "settings": {
        "foreground": "#ff9966"
      }
    },
    {
      "name": "CSS values / units",
      "scope": [
        "constant.numeric.css",
        "keyword.other.unit.css",
        "support.constant.property-value.css"
      ],
      "settings": {
        "foreground": "#ffbb55"
      }
    },
    // ── Markdown ───────────────────────────────────────────────────────────
    {
      "name": "Markdown headings",
      "scope": [
        "entity.name.section.markdown",
        "markup.heading"
      ],
      "settings": {
        "foreground": "#ff5522",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown bold",
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#ff7744",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown italic",
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#ff9966",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown code",
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": {
        "foreground": "#ff8844"
      }
    },
    {
      "name": "Markdown links",
      "scope": ["markup.underline.link"],
      "settings": {
        "foreground": "#ff6633"
      }
    },
    // ── Imports / modules ──────────────────────────────────────────────────
    {
      "name": "Module names / imports",
      "scope": [
        "entity.name.module",
        "support.module",
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from"
      ],
      "settings": {
        "foreground": "#ff4411",
        "fontStyle": "bold"
      }
    },
    // ── Decorators ─────────────────────────────────────────────────────────
    {
      "name": "Decorators / annotations",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator"
      ],
      "settings": {
        "foreground": "#ff3300",
        "fontStyle": "italic"
      }
    },
    // ── JSON keys ──────────────────────────────────────────────────────────
    {
      "name": "JSON keys",
      "scope": [
        "support.type.property-name.json",
        "string.json meta.structure.dictionary.json"
      ],
      "settings": {
        "foreground": "#ff7744"
      }
    },
    // ── Invalid / deprecated ───────────────────────────────────────────────
    {
      "name": "Invalid",
      "scope": ["invalid"],
      "settings": {
        "foreground": "#ff0000",
        "fontStyle": "bold underline"
      }
    },
    {
      "name": "Deprecated",
      "scope": ["invalid.deprecated"],
      "settings": {
        "foreground": "#cc3300",
        "fontStyle": "strikethrough"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#ff5522",
    "class": "#ff8855",
    "interface": "#ff9966",
    "enum": "#ff6622",
    "enumMember": "#ff9955",
    "function": "#ff7744",
    "method": "#ff7744",
    "property": "#ffbb77",
    "variable": "#f0c090",
    "variable.readonly": { "foreground": "#ff9944", "bold": true },
    "parameter": { "foreground": "#ffcc88", "italic": true },
    "type": "#ff9966",
    "typeParameter": "#ffaa55",
    "macro": "#ff4422",
    "decorator": { "foreground": "#ff3300", "italic": true },
    "comment": { "foreground": "#cc7744", "italic": true },
    "string": "#ffaa55",
    "number": "#ff6644",
    "keyword": { "foreground": "#ff3311", "bold": true }
  }
}
