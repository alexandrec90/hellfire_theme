    "editor.wordHighlightBackground": "#5c000060",
    "editor.wordHighlightStrongBackground": "#7a000070",
    "editor.findMatchBackground": "#cc220060",
    "editor.findMatchHighlightBackground": "#992200aa",
    "editor.inactiveSelectionBackground": "#3d000055",
    "editorCursor.foreground": "#ff4400",
    "editorCursor.background": "#000000",
    "editorLineNumber.foreground": "#5a1a1a",
    "editorLineNumber.activeForeground": "#ff5522",
    "editorIndentGuide.background1": "#2a0a0a",
    "editorIndentGuide.activeBackground1": "#661111",
    "editorWhitespace.foreground": "#3a1010",
