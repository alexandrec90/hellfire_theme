{
  "name": "hellfire-theme",
  "displayName": "Hellfire Theme",
  "description": "A blazing red and black VS Code theme with animated fire background (requires Custom CSS and JS Loader).",
  "version": "1.0.4",
  "main": "./extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "scripts": {
    "prepackage": "npm version patch --no-git-tag-version",
    "postversion": "node scripts/update-readme-version.js && node scripts/add-changelog-entry.js",
    "package": "vsce package",
    "update-settings": "node scripts/update-vscode-settings.js"
  },
  "publisher": "AlexCharbonneau",
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "theme",
    "dark",
    "red",
    "fire",
    "hellfire",
    "animated",
    "animation"
  ],
  "files": [
    "README.md",
    "LICENSE",
    "hellfire_icon.png",
    "hellfire_icon.svg",
    "extension.js",
    "themes/**",
    "custom/**"
  ],
  "contributes": {
    "themes": [
      {
        "label": "Hellfire",
        "uiTheme": "vs-dark",
        "path": "./themes/hellfire-color-theme.json"
      }
    ]
  },
  "icon": "hellfire_icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/alexandrec90/hellfire_theme"
  }
}
